@{
}

<h2>Score: @Model.Score</h2>
<h3>@Model.Recommendation</h3>

<p>@Model.Summary</p>

<table>
    @foreach (var r in Model.Requirements)
    {
        <tr>
            <td>@r.Requirement</td>
            <td>@r.Status</td>
            <td>@r.Evidence</td>
        </tr>
    }
</table>